apiVersion: v1
kind: ConfigMap
metadata:
  name: prometheus-config
  namespace: monitoring
data:
  prometheus.yml: |
    global:
      scrape_interval: 15s

    scrape_configs:

    # Prometheus Itself
    - job_name: 'prometheus'
      static_configs:
        - targets: ['localhost:9090']

    # Node Exporter
    - job_name: 'node-exporter'
      static_configs:
        - targets:
            - node-exporter.monitoring.svc.cluster.local:9100

    # Kube State Metrics
    - job_name: 'kube-state-metrics'
      static_configs:
        - targets:
            - kube-state-metrics.monitoring.svc.cluster.local:8080

    # Kubelet (cadvisor metrics)
    - job_name: 'kubelet'
      scheme: https
      tls_config:
        insecure_skip_verify: true
      bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token
      kubernetes_sd_configs:
        - role: node
      relabel_configs:
        - action: labelmap
          regex: __meta_kubernetes_node_label_(.+)
        - target_label: __address__
          replacement: kubernetes.default.svc:443
        - source_labels: [__meta_kubernetes_node_name]
          regex: (.+)
          target_label: __metrics_path__
          replacement: /api/v1/nodes/${1}/proxy/metrics/cadvisor

    # SonarQube (inside cluster)
    - job_name: 'sonarqube'
      metrics_path: /api/monitoring/metrics
      scheme: http
      static_configs:
      - targets: ['sonarqube-service.default.svc.cluster.local:9000']
      authorization:
        credentials: prom123

    # Jenkins (OUTSIDE cluster)
    - job_name: 'jenkins'
      metrics_path: /prometheus
      static_configs:
        - targets:
            - 172.31.0.200:8080
